# Environment Variables
PORT=3001
OLLAMA_URL=http://localhost:11434
DEFAULT_MODEL=llama3.2
PROJECT_ROOT=./workspace
CORS_ORIGIN=http://localhost:5173

# ChromaDB — vector database for semantic (embedding-based) RAG search
# Leave empty or unset to use BM25-only retrieval (no ChromaDB required)
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=codenative_chunks

# Ollama model used for generating text embeddings.
# Install with: ollama pull nomic-embed-text
# Other options: mxbai-embed-large, all-minilm
EMBEDDING_MODEL=nomic-embed-text

# Number of vector search results to fetch from ChromaDB (default: 8)
VECTOR_SEARCH_K=8
